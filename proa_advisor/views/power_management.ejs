<html lang="en">

<%- include('header', { title: "Power Management" }) %>

    <body class="hold-transition sidebar-mini layout-fixed">
        <div class="wrapper">
            <%- include('navbar') %>
                <%- include('sidebar') %>
                    <div class="content-wrapper">
                        <div class="content-header">
                            <div class="container-fluid">
                                <div class="row mb-2">
                                    <div class="col-sm-6">
                                        <h1 class="m-0">Power Management</h1>
                                        <button class="btn btn-primary ml-auto" id="btnToggle"
                                            onclick="togglePolling()">Stop</button>
                                    </div>
                                    <div class="col-sm-6">
                                        <ol class="breadcrumb float-sm-right">
                                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                                            <li class="breadcrumb-item active">Power Management</li>
                                        </ol>
                                    </div>
                                </div>
                                <!-- Main content -->
                                <section class="content">
                                    <div class="container-fluid">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="card card-primary card-outline">
                                                    <div class="card-header d-flex justify-content-between">
                                                        <h3 class="card-title">
                                                            <i class="far fa-chart-bar"></i>
                                                            SoC vs Time
                                                        </h3>

                                                    </div>
                                                    <div class="card-body">
                                                        <canvas id="soc_time_graph" height="100"></canvas>
                                                    </div>
                                                    <!-- /.card-body-->
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="card card-primary card-outline">
                                                    <div class="card-header d-flex justify-content-between">
                                                        <h3 class="card-title">
                                                            <i class="far fa-chart-bar"></i>
                                                            Voltage vs Time
                                                        </h3>
                                                    </div>
                                                    <div class="card-body">
                                                        <canvas id="voltage_time_graph" height="100"></canvas>
                                                    </div>
                                                    <!-- /.card-body-->
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="card card-primary card-outline">
                                                    <div class="card-header d-flex justify-content-between">
                                                        <h3 class="card-title">
                                                            <i class="far fa-chart-bar"></i>
                                                            Current vs Time
                                                        </h3>
                                                    </div>
                                                    <div class="card-body">
                                                        <canvas id="current_time_graph" height="100"></canvas>
                                                    </div>
                                                    <!-- /.card-body-->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            </div>
                        </div>
                    </div>
                    <%- include('footer') %>
        </div>

        </div>
        <%- include('script') %>
            <script>
                // Power Management Chart
                let intervalId = null;
                let isRunning = true;
                let pauseCount = 0;
                let timeSinceStart = 0;
                const maxPoints = 30;

                const soc_ctx = document.getElementById('soc_time_graph').getContext('2d'),
                    voltage_ctx = document.getElementById('voltage_time_graph').getContext('2d'),
                    current_ctx = document.getElementById('current_time_graph').getContext('2d');

                const soc_chartData = [],
                    voltage_chartData = [],
                    current_chartData = [];

                const chartDataList = [soc_chartData, voltage_chartData].map(chart => {
                    return {
                        labels: [],   // formatted timestamps for display
                        datasets: [{
                            label: 'Value',
                            data: [],   // raw numeric values
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99, 102, 241, 0.08)',
                            borderWidth: 2,
                            pointRadius: 3,
                            pointBackgroundColor: '#6366f1',
                            tension: 0.35,
                            fill: true,
                        }]
                    }
                });
                chartDataList.push({
                        labels: [],   // formatted timestamps for display
                        datasets: [{
                            label: 'Value',
                            data: [],   // raw numeric values
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99, 102, 241, 0.08)',
                            borderWidth: 2,
                            pointRadius: 3,
                            pointBackgroundColor: '#6366f1',
                            tension: 0.35,
                            fill: false,
                        }]
                    })

                const chart_list = [soc_ctx, voltage_ctx, current_ctx].map((ctx, idx) =>
                    new Chart(ctx, {
                        type: 'line',
                        data: chartDataList[idx],
                        options: {
                            animation: { duration: 0 },   // disable animation for smooth live updates
                            responsive: true,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: ctx => ` ${ctx.parsed.y.toFixed(2)}`
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    ticks: { color: '#64748b', maxTicksLimit: 8, maxRotation: 0 },
                                    grid: { color: '#1e2235' }
                                },
                                y: {
                                    ticks: { color: '#64748b' },
                                    grid: { color: '#1e2235' }
                                }
                            }
                        }
                    }));

                async function getData() {
                    timeSinceStart += Math.floor(Math.random() * 100);
                    const value = Math.random() * 100 + 100;
                    return [timeSinceStart, value];
                }

                async function tick() {

                    chartDataList.forEach(async (chartData) => {
                        const [ts, value] = await getData();
                        // Append
                        chartData.labels.push(ts);
                        chartData.datasets[0].data.push(value);

                        // Shift oldest point off once we exceed maxPoints
                        if (chartData.labels.length > maxPoints) {
                            chartData.labels.shift();
                            chartData.datasets[0].data.shift();
                        }

                        if (isRunning) {
                            chart_list.forEach(chart => chart.update());
                        }
                    })
                }

                function startPolling() {
                    const ms = 500
                    clearInterval(intervalId);
                    intervalId = setInterval(tick, ms);
                }

                function togglePolling() {
                    const btn = document.getElementById('btnToggle');
                    if (isRunning) {
                        btn.textContent = 'Start';
                        clearInterval(intervalId);
                    } else {
                        btn.textContent = 'Stop';
                        startPolling();
                    }
                    isRunning = !isRunning;
                }
                // ─── Kick things off ──────────────────────────────────────────────────────
                tick();           // immediate first point
                startPolling();   // then start regular polling
            </script>
    </body>

</html>